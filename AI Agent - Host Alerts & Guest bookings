      "parameters": {
        "jsCode": "const output = items[0].json.output;\nconst hasAlert = output.includes('[HOST_ALERT]');\n\nif (hasAlert) {\n  const parts = output.split('[HOST_ALERT]');\n  const alertContent = parts[1].trim();\n  \n  // Extract name if it follows the \"Name: [Value] |\" format\n  const nameMatch = alertContent.match(/Name:\\s*(.*?)\\s*\\|/);\n  const guestName = nameMatch ? nameMatch[1] : \"New Inquiry\";\n\n  return [{\n    json: {\n      guest_message: parts[0].trim(),\n      host_alert: alertContent.split('Note:')[1]?.trim() || alertContent,\n      guest_name: guestName,\n      send_to_host: true\n    }\n  }];\n} else {\n  return [{\n    json: {\n      guest_message: output,\n      host_alert: null,\n      guest_name: null,\n      send_to_host: false\n    }\n  }];\n}"
      },
